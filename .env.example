# ── Bagagem — variáveis de ambiente ───────────────────────────────────────────
# Copie este arquivo para `.env.local` e preencha. NUNCA comite chaves no código.
#   cp .env.example .env.local

# Chave da API Anthropic (obrigatória para o tutor + avaliador na Fase 1).
# Crie em https://console.anthropic.com/ . Sem ela, o app roda em MODO DEMO
# (respostas simuladas a partir do conteúdo verificado), útil para ver a UI.
ANTHROPIC_API_KEY=

# Modelos (opcional — há defaults sensatos no código).
# Tutor nos turnos normais e Avaliador (guarda):
ANTHROPIC_MODEL_TUTOR=claude-sonnet-4-6
ANTHROPIC_MODEL_AVALIADOR=claude-sonnet-4-6

# ── Fases futuras (ainda NÃO usadas na Fase 1) ────────────────────────────────
# Camada B — cruzamento de tradução (Fase 1.5):
# GOOGLE_TRANSLATE_API_KEY=
# Voz / TTS (Fase 2):
# OPENAI_API_KEY=
# ELEVENLABS_API_KEY=
# Pronúncia (Fase 3):
# AZURE_SPEECH_KEY=
# AZURE_SPEECH_REGION=
